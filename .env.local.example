# ============================================
# Firebase Client SDK（公開，可放前端）
# Firebase Console > 專案設定 > 應用程式 取得
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyDgaraW-DWdgtLo0O_a2Yifgc8EAwb500s"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="rlgbid.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_DATABASE_URL="https://rlgbid-default-rtdb.asia-southeast1.firebasedatabase.app"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="rlgbid"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="rlgbid.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="710926876647"
NEXT_PUBLIC_FIREBASE_APP_ID="1:710926876647:web:763eba04751fcb9b86c742"

# ============================================
# Firebase Admin SDK（SERVER 端私鑰，絕對不能加 NEXT_PUBLIC_）
# Firebase Console > 專案設定 > 服務帳戶 > 產生私鑰
# 下載 JSON 後填入以下三個欄位
# ============================================
FIREBASE_ADMIN_PROJECT_ID="rlgbid"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk-xxxx@rlgbid.iam.gserviceaccount.com"
# 注意：私鑰換行符號需改成 \n（一行填入）
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ============================================
# LINE Login（在 LINE Developers Console 設定）
# https://developers.line.biz/console/
# ============================================
LINE_CHANNEL_ID="2009690208"
LINE_CHANNEL_SECRET="42d7ef27f8f4690c3f4ab91142c9e982"
# Callback URL 必須在 LINE Console > Callback URL 中設定
LINE_CALLBACK_URL="https://yourdomain.com/api/auth/line/callback"

# ============================================
# LINE 官方帳號（用於 QR Code）
# 格式：@your-line-id（含 @ 符號）
# ============================================
NEXT_PUBLIC_LINE_OA_ID="@your-line-oa-id"

# ============================================
# 網站 URL（用於 QR Code & 分享連結）
# ============================================
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ============================================
# 管理員 UID
# LINE 登入的 UID 格式為 line:{lineUserId}
# 在 Firebase Auth 或 Realtime Database users/ 查詢
# ============================================
NEXT_PUBLIC_ADMIN_UIDS="line:Uxxxxxxxx,uid2"

# ============================================
# CRM / n8n 串接（SERVER 端，絕對不能加 NEXT_PUBLIC_）
# n8n > Workflows > Webhook node 取得觸發 URL
# ============================================

# Workflow B 接收入口（競標/成交/任務事件）
N8N_WEBHOOK_URL="https://your-n8n.com/webhook/bidnow-events"

# HMAC-SHA256 簽名金鑰（與 n8n 端設定一致，建議 32 字元以上隨機字串）
# 產生方式：openssl rand -hex 32
N8N_WEBHOOK_SECRET="your-hmac-secret-at-least-32-chars"

# ============================================
# 舊版 webhook（已停用，改用上方 N8N_WEBHOOK_URL）
# ============================================
# NEXT_PUBLIC_WEBHOOK_URL="https://your-n8n.com/webhook/auction-bid"
